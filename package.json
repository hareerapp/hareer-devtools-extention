{
  "name": "hareer-devtools",
  "displayName": "Hareer DevTools",
  "description": "ClickUp task manager, code review, and Makefile runner for the Hareer monorepo.",
  "version": "0.1.0",
  "publisher": "hareer",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ISCQI/hareer-mono.git",
    "directory": "apps/vscode-extension"
  },
  "icon": "media/favicon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscode.github-authentication"
  ],
  "activationEvents": [
    "workspaceContains:Makefile",
    "workspaceContains:.gitmodules"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc --noEmit -p ."
  },
  "contributes": {
    "commands": [
      {
        "command": "hareer.runTarget",
        "title": "Hareer: Run Make Target"
      },
      {
        "command": "hareer.refresh",
        "title": "Hareer: Refresh Makefile Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "hareer.refreshCodeReview",
        "title": "Hareer: Refresh Code Review",
        "icon": "$(refresh)"
      },
      {
        "command": "hareer.selectPR",
        "title": "Change Pull Request",
        "icon": "$(edit)"
      },
      {
        "command": "hareer.openDiff",
        "title": "Hareer: Open Diff"
      },
      {
        "command": "hareer.postComment",
        "title": "Submit",
        "icon": "$(check)"
      },
      {
        "command": "hareer.approveReview",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "hareer.requestChangesReview",
        "title": "Request Changes",
        "icon": "$(request-changes)"
      },
      {
        "command": "hareer.submitReview",
        "title": "Submit Review",
        "icon": "$(send)"
      },
      {
        "command": "hareer.mergePR",
        "title": "Merge Pull Request",
        "icon": "$(git-merge)"
      },
      {
        "command": "hareer.connectClickUp",
        "title": "Hareer: Connect ClickUp",
        "icon": "$(plug)"
      },
      {
        "command": "hareer.disconnectClickUp",
        "title": "Hareer: Disconnect ClickUp"
      },
      {
        "command": "hareer.switchClickUpWorkspace",
        "title": "Hareer: Switch ClickUp Workspace",
        "icon": "$(organization)"
      },
      {
        "command": "hareer.refreshTasks",
        "title": "Hareer: Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "hareer.openTaskDetail",
        "title": "Hareer: Open Task Detail"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hareer",
          "title": "Hareer DevTools",
          "icon": "media/favicon.png"
        }
      ]
    },
    "views": {
      "hareer": [
        {
          "id": "hareerTaskManager",
          "name": "Task Manager"
        },
        {
          "id": "hareerCodeReview",
          "name": "Code Review"
        },
        {
          "id": "hareerMakeTargets",
          "name": "Makefile Commands"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hareerTaskManager",
        "contents": "Connect your ClickUp account to see tasks assigned to you.\n[Connect ClickUp](command:hareer.connectClickUp)\n\nYou'll need a Personal API Token from ClickUp: avatar → Settings → Apps, or Workspace Settings → ClickUp API.",
        "when": "!hareer.clickup.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hareer.refresh",
          "when": "view == hareerMakeTargets",
          "group": "navigation"
        },
        {
          "command": "hareer.refreshCodeReview",
          "when": "view == hareerCodeReview",
          "group": "navigation"
        },
        {
          "command": "hareer.refreshTasks",
          "when": "view == hareerTaskManager && hareer.clickup.connected",
          "group": "navigation@1"
        },
        {
          "command": "hareer.switchClickUpWorkspace",
          "when": "view == hareerTaskManager && hareer.clickup.connected",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hareer.selectPR",
          "when": "view == hareerCodeReview && viewItem == prSelectorActive",
          "group": "inline@1"
        },
        {
          "command": "hareer.submitReview",
          "when": "view == hareerCodeReview && viewItem == prSelectorActive",
          "group": "inline@2"
        },
        {
          "command": "hareer.mergePR",
          "when": "view == hareerCodeReview && viewItem == prSelectorActive",
          "group": "inline@3"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "hareer.postComment",
          "when": "commentController == hareerReview",
          "group": "inline"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "hareer.approveReview",
          "when": "commentController == hareerReview",
          "group": "navigation@1"
        },
        {
          "command": "hareer.requestChangesReview",
          "when": "commentController == hareerReview",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Hareer DevTools",
      "properties": {
        "hareer.clickup.prUrlFieldName": {
          "type": "string",
          "default": "Github PR Url",
          "description": "Name of the ClickUp custom field that holds the GitHub PR URL."
        },
        "hareer.clickup.autoTransition": {
          "type": "boolean",
          "default": false,
          "description": "Automatically move ClickUp tasks between statuses when you create branches and push."
        },
        "hareer.clickup.branchTypes": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["feature", "bugfix", "hotfix", "chore", "docs", "refactor"],
          "description": "Available branch types in the Task Manager."
        },
        "hareer.clickup.pollIntervalMs": {
          "type": "number",
          "default": 0,
          "description": "Auto-refresh task list at this interval (ms). 0 disables polling."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.3"
  }
}
